<!--
  UAV LiDAR Stack - Hector SLAM Launch
  ======================================
  Configures and starts hector_mapping for LiDAR-only 2D SLAM.

  hector_mapping publishes:
    /map           (nav_msgs/OccupancyGrid)  - 2D occupancy grid map
    /map_metadata  (nav_msgs/MapMetaData)    - map properties
    /slam_out_pose (geometry_msgs/PoseStamped) - estimated robot pose
    /tf: map → base_link                      - localisation transform

  Input:
    /scan  (sensor_msgs/LaserScan) - from lidar_processing stack

  The map can be saved with:
    rosrun map_server map_saver -f /path/to/map
-->
<launch>

  <arg name="use_sim_time" default="true"/>
  <param name="use_sim_time" value="$(arg use_sim_time)"/>

  <!-- ===== hector_mapping node ===== -->
  <node name="hector_mapping" pkg="hector_mapping" type="hector_mapping"
        output="screen" clear_params="true">

    <!-- Frame configuration -->
    <param name="map_frame"  value="map"/>
    <param name="base_frame" value="base_link"/>
    <param name="odom_frame" value="base_link"/>

    <!-- Map geometry -->
    <param name="map_resolution"     value="0.05"/>
    <param name="map_size"           value="1024"/>
    <param name="map_start_x"        value="0.5"/>
    <param name="map_start_y"        value="0.5"/>

    <!-- Map update thresholds -->
    <param name="map_update_distance_thresh" value="0.05"/>
    <param name="map_update_angle_thresh"    value="0.0873"/>

    <!-- Scan parameters -->
    <param name="laser_min_dist" value="0.1"/>
    <param name="laser_max_dist" value="50.0"/>
    <param name="laser_z_min_value" value="-0.2"/>
    <param name="laser_z_max_value" value=" 0.2"/>

    <!-- Occupancy update probabilities -->
    <param name="update_factor_free"     value="0.4"/>
    <param name="update_factor_occupied" value="0.9"/>

    <!-- Multi-resolution levels (more = more robust, more CPU) -->
    <param name="map_multi_res_levels" value="3"/>

    <!-- TF and pose publishing -->
    <param name="pub_map_to_baselink_transform" value="true"/>
    <param name="pub_map_odom_transform"        value="true"/>
    <param name="output_timing"                 value="false"/>
    <param name="scan_subscriber_queue_size"    value="5"/>
    <param name="use_tf_scan_transformation"    value="true"/>
    <param name="advertise_map_service"         value="true"/>

    <!-- Topic: use /scan from our lidar_processor -->
    <remap from="scan" to="/scan"/>

  </node>

</launch>

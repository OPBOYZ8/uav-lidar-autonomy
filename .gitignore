# =============================================================================
# UAV LiDAR Autonomy — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# ROS / catkin build artifacts
# ---------------------------------------------------------------------------
catkin_ws/build/
catkin_ws/devel/
catkin_ws/install/
catkin_ws/logs/
catkin_ws/.catkin_workspace

# Python bytecode inside packages
catkin_ws/src/**/__pycache__/
catkin_ws/src/**/*.pyc
catkin_ws/src/**/*.pyo

# catkin_tools
.catkin_tools/

# ---------------------------------------------------------------------------
# Gazebo / simulation runtime files
# ---------------------------------------------------------------------------
~/.gazebo/
*.bag                    # ROS bag recordings — usually too large for git
*.db                     # SQLite ROS log databases

# ---------------------------------------------------------------------------
# Build logs (generated by scripts/build.sh)
# ---------------------------------------------------------------------------
build.log
*.log

# ---------------------------------------------------------------------------
# Saved maps (generated at runtime by map_server)
# ---------------------------------------------------------------------------
catkin_ws/src/uav_lidar_mapping/maps/*.pgm
catkin_ws/src/uav_lidar_mapping/maps/*.yaml

# ---------------------------------------------------------------------------
# Python virtual environments
# ---------------------------------------------------------------------------
venv/
.venv/
env/

# ---------------------------------------------------------------------------
# IDE and editor artefacts
# ---------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# Images and media (track only committed demo assets, not local exports)
# ---------------------------------------------------------------------------
images/*.mp4
images/*.avi
images/*.bag

# Keep placeholder file
!images/PLACEHOLDER.md
